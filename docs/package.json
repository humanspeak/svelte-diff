{
    "name": "docs",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsx ./scripts/fetch-github-stats.ts && vite build",
        "build:indexnow": "tsx ./scripts/fetch-github-stats.ts && vite build --mode indexnow",
        "cf-typegen": "wrangler types && mv worker-configuration.d.ts src/",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "deploy": "pnpm run build:indexnow && wrangler deploy",
        "dev": "vite dev",
        "preview": "vite preview"
    },
    "dependencies": {
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "@humanspeak/docs-kit": "github:humanspeak/docs-kit#2026.7.6",
        "@humanspeak/svelte-diff": "workspace:*",
        "@humanspeak/svelte-markdown": "^1.8.3",
        "runed": "^0.37.1"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^5.20260715.1",
        "@eslint/compat": "^2.1.0",
        "@eslint/js": "^10.0.1",
        "@humanspeak/svelte-motion": "^0.7.13",
        "@lucide/svelte": "^1.24.0",
        "@sveltejs/adapter-cloudflare": "^7.2.9",
        "@sveltejs/kit": "^2.69.3",
        "@sveltejs/vite-plugin-svelte": "^7.2.0",
        "@tailwindcss/typography": "^0.5.20",
        "@tailwindcss/vite": "^4.3.2",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.20.0",
        "globals": "^17.7.0",
        "mdsvex": "^0.12.7",
        "mode-watcher": "^1.1.0",
        "prettier": "^3.9.5",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-svelte": "^4.1.1",
        "prettier-plugin-tailwindcss": "^0.8.1",
        "shiki": "^4.3.1",
        "svelte": "^5.56.5",
        "svelte-check": "^4.7.2",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.2",
        "tsx": "^4.23.1",
        "typescript": "6.0.3",
        "typescript-eslint": "^8.64.0",
        "vite": "^8.1.4",
        "wrangler": "4.111.0"
    },
    "volta": {
        "node": "24.15.0"
    }
}
